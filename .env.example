# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Frontend API base URL
# Web 同域部署时可留空；移动端独立构建时请填写完整后端地址，例如 https://api.example.com
VITE_API_BASE_URL=

# Capacitor live reload / 真机调试地址
# 例如 http://192.168.1.10:3000
CAPACITOR_SERVER_URL=

# SiliconFlow chat completion
# Required for generating the structured mystic recipe result.
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_MODEL=nex-agi/Nex-N2-Pro

# Volcengine Ark image generation
# Used for dish image generation.
ARK_API_KEY=your_ark_api_key
ARK_MODEL=ep-20260531002257-flngb
